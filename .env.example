# ============================================================================
# My Health Access - Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ============================================================================
# Anthropic API (Required)
# ============================================================================
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# Firebase Configuration (Required for authentication)
# ============================================================================
# Get these from Firebase Console > Project Settings > General
FIREBASE_API_KEY=AIza...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id

# ============================================================================
# MCP Transport Security (Required)
# ============================================================================
# Generate secure tokens with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# Bearer token for backend-to-MCP server authentication
MCP_INTERNAL_TOKEN=your-generated-token-here

# Secret for signing auth_context JWTs passed to MCP server
MCP_JWT_SECRET=your-generated-secret-here

# ============================================================================
# MCP Server Configuration
# ============================================================================
# URL of the MCP server. Override for Cloud Run deployment.
# Local: http://localhost:8001
# Cloud Run: https://your-mcp-service-xxxxx-uc.a.run.app
MCP_SERVER_URL=http://localhost:8001

# ============================================================================
# Application Settings
# ============================================================================
# Set to "true" for local development only. Never true in production.
DEBUG=false

# Log level. Use DEBUG for local development, INFO for production.
LOG_LEVEL=INFO

# Port for the backend server (Cloud Run uses PORT env var)
PORT=8080

# ============================================================================
# CORS Configuration (Optional)
# ============================================================================
# Comma-separated list of allowed origins. Overrides config.yaml.
# Leave empty to use config.yaml defaults.
# Example: CORS_ORIGINS=https://ai-wtf.xyz,https://www.ai-wtf.xyz
CORS_ORIGINS=

# ============================================================================
# Database Configuration (Required)
# ============================================================================
# PostgreSQL connection string.
#
# Local development (with Cloud SQL Auth Proxy running):
#   DB_CONNECTION_STRING=postgresql://healthcare_user:YOUR_PASSWORD@localhost:5432/healthcare
#
# Production (Cloud Run with Cloud SQL Unix socket):
#   DB_CONNECTION_STRING=postgresql://healthcare_user:YOUR_PASSWORD@/healthcare?host=/cloudsql/PROJECT:REGION:INSTANCE
#
DB_CONNECTION_STRING=postgresql://healthcare_user:changeme@localhost:5432/healthcare
